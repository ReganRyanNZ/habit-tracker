// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User from Clerk
model User {
  id            String    @id // Clerk user ID
  habitGroup    HabitGroup?
  followedGroups Follow[] // Groups this user follows
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Each user has ONE habit group
model HabitGroup {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   @default("My Habits")
  habits      Habit[]
  followers   Follow[]
  shareToken   String   @unique @default(cuid()) // For sharing with others
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Habits belong to a group
model Habit {
  id          String   @id @default(cuid())
  groupId     String
  group       HabitGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String
  completions String   @default("{}") // JSON: dateKey -> boolean
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([groupId])
}

// Following relationships (view-only access)
model Follow {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId     String
  group       HabitGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}
